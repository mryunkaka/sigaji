{
  "name": "sigaji",
  "version": "1.0.0",
  "private": true,
  "description": "SIGAJI Native asset pipeline",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./resources/css/app.css -o ./public/assets/app.css --minify",
    "build:js": "esbuild ./resources/js/app.js --bundle --minify --outfile=./public/assets/app.js",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "tailwindcss": "^3.4.17"
  }
}
